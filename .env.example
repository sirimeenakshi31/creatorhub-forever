# ============================================================
# CreatorHub by Siri — Environment Variables (local development)
# ============================================================
# Copy this file to `.env` and fill in the values you need.
# All keys are OPTIONAL — the app will fall back to mock outputs
# when a key is missing so every tool stays usable.
#
# .env is loaded by Vite (server side) automatically.
# Never commit `.env` to git.
# ============================================================

# --- Lovable AI Gateway (powers /api/ai/text and /api/ai/image) ---
# One key unlocks chat completions + image generation through Lovable.
# Get one at https://lovable.dev (enable Lovable Cloud on a project).
LOVABLE_API_KEY=

# --- ElevenLabs (powers /api/audio TTS and /api/transcribe STT) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# --- Replicate (powers /api/replicate/run, /api/video, /api/face-swap) ---
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Optional: OpenAI (only if you wire OpenAI-specific tools) ---
OPENAI_API_KEY=
